# Reverse proxy для выделенного сервера по IP во ВНУТРЕННЕЙ сети — без TLS (plain HTTP).
# Слушаем :80 на всех интерфейсах контейнера (`bind 0.0.0.0` — самого IP внутри нет).
#
# ВНИМАНИЕ: HTTP без шифрования. Секрет вебхука и тело запроса идут по сети открытым
# текстом — применять ТОЛЬКО в изолированном доверенном сегменте. Аутентификация вебхуков
# (X-Gitlab-Token / application_token) при этом работает как и прежде.
#
# Вернуть TLS (self-signed по IP): раскомментировать блок default_sni, заменить адрес на
# `https://10.0.0.111`, добавить `tls internal`. Для домена — `example.com` + ACME (без bind).
# {
# 	default_sni 10.0.0.111
# }

http://10.0.0.111 {
	bind 0.0.0.0

	encode gzip

	# Ограничение размера входящего payload (совпадает с WEBHOOK_MAX_BODY_MB).
	request_body {
		max_size 5MB
	}

	# Наружу открыты только вебхуки и health-пробы. /metrics и /internal — НЕ публиковать.
	@public path /bitrix-webhook /gitlab-webhook /healthz /readyz
	handle @public {
		reverse_proxy api:8080
	}

	handle {
		respond "Not found" 404
	}

	log {
		output stdout
		format json
	}
}
