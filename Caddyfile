# Reverse proxy для выделенного сервера по IP (без домена): self-signed TLS.
# Адрес сайта (10.0.0.111) задаёт SAN сертификата и матчинг Host; слушаем на всех
# интерфейсах контейнера через `bind 0.0.0.0` (самого IP внутри контейнера нет).
# Для домена: замените адрес на example.com и уберите `bind`/`tls internal`/`default_sni` —
# Caddy получит доверенный сертификат автоматически (ACME).
{
	# Клиент идёт по IP -> в ClientHello нет SNI; отдаём сертификат этого сайта по умолчанию.
	default_sni 10.0.0.111
}

https://10.0.0.111 {
	bind 0.0.0.0
	tls internal

	encode gzip

	# Ограничение размера входящего payload (совпадает с WEBHOOK_MAX_BODY_MB).
	request_body {
		max_size 5MB
	}

	# Наружу открыты только вебхуки и health-пробы. /metrics и /internal — НЕ публиковать.
	@public path /bitrix-webhook /gitlab-webhook /healthz /readyz
	handle @public {
		reverse_proxy api:8080
	}

	handle {
		respond "Not found" 404
	}

	log {
		output stdout
		format json
	}
}
