# Скопировать в .env. Секреты в production — через Docker secrets / Vault, не сюда.
APP_ENV=dev
DEBUG=false

BRIEFING_DB_URL=postgresql+asyncpg://ai_developer:ai_developer@postgres:5432/ai_developer
REDIS_URL=redis://redis:6379/0

# LLM
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1   # сменить для self-hosted / OpenAI-совместимого
LLM_MODEL=gpt-4o-mini

# GitLab
GITLAB_URL=
GITLAB_TOKEN=                               # роль Developer, scope api, least privilege
GITLAB_WEBHOOK_SECRET=                      # свой случайный; = Secret token вебхука GitLab
GITLAB_GROUP=
CI_BOT_USERNAME=ai-developer-bot

# Bitrix24
BITRIX_URL=                                 # ВХОДЯЩИЙ вебхук: https://<портал>/rest/<uid>/<code>/
BITRIX_APP_TOKEN=                           # application_token ИСХОДЯЩЕГО вебхука
# ОБЯЗАТЕЛЬНО: маппинг нормализованных ключей на UF_*-поля задач портала.
# Без него intake не прочитает поля задачи -> каждая задача уйдёт в брифинг.
BITRIX_FIELD_MAP={"task_type":"UF_AUTO_123","target_repo":"UF_AUTO_124","business_goal":"UF_AUTO_125","acceptance_criteria":"UF_AUTO_126","affected_area":"UF_AUTO_127","reviewer":"UF_AUTO_128"}

# Ветвление: auto-task-* форкается от FORK_BASE_BRANCH, MR нацелен в DEFAULT_BASE_BRANCH
DEFAULT_BASE_BRANCH=dev
FORK_BASE_BRANCH=main

# Брифинг
MAX_BRIEFING_ROUNDS=3
MAX_QUESTIONS_PER_ROUND=4
BRIEFING_IDLE_TIMEOUT_HOURS=72
HIGH_RISK_GO_REQUIRES_MAINTAINER=true
# Кто может авторизовать /go помимо creator/reviewer/maintainer/responsible.
# JSON-массив id, например ["123","456"]; пустой список = никто дополнительно.
AI_GO_APPROVERS=[]

# Лимиты и scope
MAX_TOKENS_PER_TASK=200000
PHASE_TIMEOUT_SEC=600
MAX_AI_FIXES=3
MAX_CODE_ITERATIONS=3        # попыток генерации с прогоном проверок репо
MAX_CHANGED_FILES_LOW=5      # выше -> risk medium
MAX_CHANGED_FILES_MEDIUM=15  # выше -> нужен человек
MAX_DIFF_LINES_AUTO=500      # дифф больше -> MR остаётся Draft человеку

# Контуры
RED_TEAM_ENABLED=true
PREVIEW_ENABLED=false

# Песочница проверок репо.
# false (fail-closed дефолт): команды из .ai-agent.yml НЕ запускаются -> MR выходит unverified.
# true ставить ТОЛЬКО в реально изолированном воркере (контейнер) — это запуск недоверенных
# команд из чужого репо. На dev-ноуте держать false.
SANDBOX_ISOLATION_CONFIRMED=false

# Граф кода для Explore & Plan (graphify); строится офлайн, обновляется на задаче
GRAPH_AUTO_BUILD=true
GRAPH_REFRESH_ON_TASK=true

# Инфраструктура
WORKER_CONCURRENCY=1
METRICS_ENABLED=true
LOG_REDACTION_ENABLED=true
# Токен для /internal/* (cancel и пр.). Задать обязательно, если порт смотрит наружу.
INTERNAL_API_TOKEN=
